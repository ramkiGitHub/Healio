# ─────────────────────────────────────────────────────────────────────────────
# Healio — Environment Variable Template
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to version control.
# Variables marked [REQUIRED] will cause the app to fail fast on startup.
# Variables marked [PLACEHOLDER] are for future integrations — leave blank
# for now; the app will run without them.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ────────────────────────────────────────────────────────────────
# Environment name: controls logging verbosity and debug features.
# Values: development | production
APP_ENV=development

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO


# ── OpenAI [REQUIRED] ─────────────────────────────────────────────────────────
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your-key-here-replace-with-actual-key
# The model used for all patient conversations and intent routing.
# Default: gpt-4o-mini (cost-effective; upgrade to gpt-4o post-pilot if needed)
OPENAI_MODEL=gpt-4o-mini

# Maximum tokens the LLM may generate in a single response.
OPENAI_MAX_TOKENS=512

# Temperature for LLM responses (0.0 = deterministic, 1.0 = creative).
# 0.2 recommended for medical contexts to reduce hallucinations.
OPENAI_TEMPERATURE=0.2


# ── LangSmith Tracing [REQUIRED] ──────────────────────────────────────────────
# Sign up at: https://smith.langchain.com/
# Enables full LangGraph trace logging (every node, LLM call, token count).
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=healio-mvp


# ── Telegram [REQUIRED] ───────────────────────────────────────────────────────
# Create a Telegram bot via @BotFather and copy the token here.
# Docs: https://core.telegram.org/bots/tutorial
TELEGRAM_BOT_TOKEN=

# Telegram chat ID of the on-call doctor/nurse for Human-in-the-Loop alerts.
# To find your chat ID: message @userinfobot on Telegram.
DOCTOR_CHAT_ID=

# Seconds to wait for a doctor acknowledgment before auto-escalating.
# After this timeout the patient receives a fallback safety message.
ALERT_TIMEOUT_SECONDS=30

# The public URL where Telegram will deliver webhook events.
# Format: https://your-domain.com
# Leave blank during local development (polling mode will be used instead).
TELEGRAM_WEBHOOK_URL=


# ── WhatsApp [PLACEHOLDER] ────────────────────────────────────────────────────
# Leave all WhatsApp variables blank for MVP. The /webhook/whatsapp endpoint
# will return 501 Not Implemented until these are configured.
#
# --- Option A: Twilio ---
# Sign up at: https://www.twilio.com/whatsapp
# Set WHATSAPP_PROVIDER=twilio and fill in:
WHATSAPP_PROVIDER=
WHATSAPP_ACCOUNT_SID=
WHATSAPP_AUTH_TOKEN=
WHATSAPP_FROM_NUMBER=

# --- Option B: Meta Cloud API ---
# Apply at: https://developers.facebook.com/docs/whatsapp/cloud-api
# Set WHATSAPP_PROVIDER=meta and fill in:
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=


# ── Google Calendar [PLACEHOLDER] ─────────────────────────────────────────────
# Leave CALENDAR_PROVIDER=mock for MVP.
# The mock provider returns hardcoded appointment slots — no credentials needed.
#
# To activate Google Calendar:
# 1. Create a Google Cloud project: https://console.cloud.google.com/
# 2. Enable the Google Calendar API
# 3. Create a Service Account and download the JSON credentials
# 4. Share your clinic calendar with the service account email
# 5. Set CALENDAR_PROVIDER=google and fill in:
CALENDAR_PROVIDER=mock
GOOGLE_CALENDAR_CREDENTIALS_PATH=
GOOGLE_CALENDAR_ID=


# ── Database ───────────────────────────────────────────────────────────────────
# SQLite for MVP (zero setup, stored in data/db/healio.db).
# To migrate to PostgreSQL post-MVP, change to:
#   DATABASE_URL=postgresql+asyncpg://user:password@host:5432/healio
DATABASE_URL=sqlite+aiosqlite:///./data/db/healio.db


# ── HuggingFace / BioBERT ─────────────────────────────────────────────────────
# Model used for medical Named Entity Recognition (symptoms, conditions).
# The model is downloaded automatically on first startup (~400 MB).
# Override to use a locally cached path: /path/to/model
BIOBERT_MODEL=d4data/biomedical-ner-all

# Set to true to disable BioBERT and use rule-based severity only.
# Useful for fast startup during development.
DISABLE_BIOBERT=false
